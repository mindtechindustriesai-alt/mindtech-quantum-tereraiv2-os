# Environment
ENVIRONMENT=development
DEBUG=True

# IBM Quantum
IBM_QUANTUM_TOKEN=your_token_here
IBM_QUANTUM_INSTANCE=ibm-q/your-instance

# Security
SECRET_KEY=your-secret-key
JWT_SECRET_KEY=your-jwt-secret

# API
API_HOST=0.0.0.0
API_PORT=8000

# Quantum Engine
DEFAULT_BACKEND=ibm_simulator
DEFAULT_SHOTS=1024
MIN_QUANTUM_EFFICIENCY=0.70

# Logging
LOG_LEVEL=INFO
